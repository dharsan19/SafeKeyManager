# ─────────────────────────────────────────────────────────────
# SafeKey Manager — Environment Variables
# Copy to .env and fill in real values before running docker-compose
# NEVER commit .env to version control
# ─────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=skm_user
POSTGRES_PASSWORD=CHANGE_ME_USE_A_STRONG_RANDOM_PASSWORD

# JWT secret — must be at least 64 characters for HS512
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000
