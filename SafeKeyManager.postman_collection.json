{
  "info": {
    "_postman_id": "safekeymanager-api-collection",
    "name": "SafeKeyManager API",
    "description": "Complete API collection for SafeKey Manager — zero-knowledge password vault.\n\nSetup: After running Login, the accessToken, refreshToken, and kdfSalt variables are auto-populated.\n\nNote: Vault entries contain client-side encrypted blobs. The example values below are illustrative — in real use, encryption happens via the browser's Web Crypto API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:8080", "type": "string" },
    { "key": "accessToken",  "value": "",                      "type": "string" },
    { "key": "refreshToken", "value": "",                      "type": "string" },
    { "key": "kdfSalt",      "value": "",                      "type": "string" },
    { "key": "entryId",      "value": "1",                     "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"masterPassword\": \"MyStrongPassword123!\"\n}"
            },
            "description": "Register a new account. Returns JWT tokens and kdfSalt for client-side vault key derivation.\n\nThe server BCrypt-hashes the master password. It is never stored in plaintext."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const data = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken',  data.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', data.refreshToken);",
                  "    pm.collectionVariables.set('kdfSalt',      data.kdfSalt);",
                  "    pm.test('Registration successful', () => pm.response.to.have.status(201));",
                  "    pm.test('Response has accessToken',  () => pm.expect(data.accessToken).to.be.a('string'));",
                  "    pm.test('Response has kdfSalt',      () => pm.expect(data.kdfSalt).to.be.a('string'));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"masterPassword\": \"MyStrongPassword123!\"\n}"
            },
            "description": "Login and receive JWT tokens + kdfSalt.\n\nThe kdfSalt is used by the client to derive the vault encryption key via PBKDF2WithHmacSHA256 (310,000 iterations). The vault key NEVER leaves the browser."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const data = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken',  data.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', data.refreshToken);",
                  "    pm.collectionVariables.set('kdfSalt',      data.kdfSalt);",
                  "    pm.test('Login successful',         () => pm.response.to.have.status(200));",
                  "    pm.test('Has accessToken',          () => pm.expect(data.accessToken).to.be.a('string'));",
                  "    pm.test('Has refreshToken',         () => pm.expect(data.refreshToken).to.be.a('string'));",
                  "    pm.test('Has kdfSalt',              () => pm.expect(data.kdfSalt).to.be.a('string'));",
                  "    pm.test('tokenType is Bearer',      () => pm.expect(data.tokenType).to.eql('Bearer'));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "refresh"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "description": "Exchange a refresh token for a new access token. Refresh tokens expire after 7 days."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const data = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken',  data.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', data.refreshToken);",
                  "    pm.test('Token refreshed', () => pm.response.to.have.status(200));",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Vault",
      "item": [
        {
          "name": "Get All Entries",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/vault",
              "host": ["{{baseUrl}}"],
              "path": ["api", "vault"]
            },
            "description": "Returns all vault entries for the authenticated user as encrypted blobs. The client decrypts them using the in-memory vault key (derived from master password + kdfSalt)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response is array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Entry",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/vault",
              "host": ["{{baseUrl}}"],
              "path": ["api", "vault"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"siteName\": \"GitHub\",\n  \"siteUrl\": \"https://github.com\",\n  \"usernameEncrypted\": \"BASE64_ENCODED_IV_PLUS_CIPHERTEXT_PLUS_TAG\",\n  \"passwordEncrypted\": \"BASE64_ENCODED_IV_PLUS_CIPHERTEXT_PLUS_TAG\",\n  \"notesEncrypted\": \"\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Create a new vault entry. All credential fields must be encrypted client-side using AES-256-GCM before sending.\n\nFormat: Base64(iv[12] || ciphertext || gcm_tag[16])"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const data = pm.response.json();",
                  "    pm.collectionVariables.set('entryId', String(data.id));",
                  "    pm.test('Entry created', () => pm.response.to.have.status(201));",
                  "    pm.test('Has id', () => pm.expect(data.id).to.be.a('number'));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Entry",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/vault/{{entryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "vault", "{{entryId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"siteName\": \"GitHub (updated)\",\n  \"siteUrl\": \"https://github.com\",\n  \"usernameEncrypted\": \"BASE64_ENCODED_UPDATED_BLOB\",\n  \"passwordEncrypted\": \"BASE64_ENCODED_UPDATED_BLOB\",\n  \"notesEncrypted\": \"BASE64_ENCODED_UPDATED_NOTES_BLOB\"\n}"
            },
            "description": "Update an existing vault entry. Ownership is enforced — users can only update their own entries (no IDOR)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Entry",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/vault/{{entryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "vault", "{{entryId}}"]
            },
            "description": "Delete a vault entry. Ownership enforced — users can only delete their own entries."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 204', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
